# Integers
1
1_000
5
0x1A
0xFFFFFF

# Floats
1.15
1_100.13
1.1e10

# Boolean
true
false

#Strings
"minha string"
"minha \"string\" com delimiter \""

# Atoms
:a
:"my atom utf8 with double quotes (\") delimiter"
:'my atom utf8 with single quotes (\') delimiter'

# Charlist
'a'

# nil
nil

# Lists with integer
[1,2,3]

# Lists with mixed
[1,:a,:b]

# Tuple with integer
{1,2,3}

# Tuple with mixed
{1,:a,:b}

# Tuple inside list
[{:a, 1}]
[{:a, 1}, {:a, 2}]

# keyword list
[a: 1]
[a: 1, b: 21]
[a: 1, b: 21, c: 3]
a: 1, b: 21

# module name
:A1
A
A.B.C
